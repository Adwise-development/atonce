{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "atonce/footer",
	"version": "1.0.0",
	"title": "Stopka",
	"category": "theme",
	"description": "Sekcja stopki: dane firmy, dwie kolumny linków, kontakt i social media.",
	"textdomain": "adwise",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"attributes": {
		"anchor": { "type": "string" },
		"className": { "type": "string" },
		"companyInfo": {
			"type": "string",
			"default": "AT ONCE SP. Z O. O.<br>ul. Gabriela Narutowicza 57/4<br>20-016 Lublin<br>KRS 0000937147<br>NIP 712-342-77-45<br>Kapitał zakładowy: 50 000,00 zł"
		},
		"linksCol1": {
			"type": "array",
			"default": [
				{ "label": "O nas", "url": "/o-nas/" },
				{ "label": "Blog", "url": "/blog/" },
				{ "label": "Usługi", "url": "/doradztwo/" },
				{ "label": "Portfolio", "url": "/#portfolio" }
			]
		},
		"linksCol2": {
			"type": "array",
			"default": [
				{ "label": "Kontakt", "url": "/kontakt/" },
				{ "label": "Polityka prywatności", "url": "/polityka-prywatnosci/" }
			]
		},
		"phone": { "type": "string", "default": "+48 575 127 152" },
		"email": { "type": "string", "default": "hello@atonce.pl" },
		"socialFacebook": {
			"type": "string",
			"default": "https://www.facebook.com/profile.php?id=100090153201756"
		},
		"socialInstagram": {
			"type": "string",
			"default": "https://www.instagram.com/atonce.pl/"
		},
		"socialLinkedin": {
			"type": "string",
			"default": "https://www.linkedin.com/company/at-once-pl/"
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"customClassName": true,
		"align": [ "wide", "full" ],
		"color": false,
		"spacing": false
	}
}
