{
  "name": "adwise",
  "version": "1.0.0",
  "description": "Adwise — blueprint block theme (Figma → Gutenberg workflow)",
  "private": true,
  "scripts": {
    "start": "webpack --config webpack.config.js --watch --mode development",
    "build": "webpack --config webpack.config.js --mode production",
    "lint:js": "wp-scripts lint-js blocks --no-error-on-unmatched-pattern",
    "lint:css": "wp-scripts lint-style \"blocks/**/*.scss\" --allow-empty-input",
    "format": "wp-scripts format blocks"
  },
  "devDependencies": {
    "@wordpress/scripts": "^30.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "glob": "^11.0.0"
  },
  "dependencies": {
    "swiper": "^12.2.0"
  }
}
