{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1600px",
			"wideSize": "1792px"
		},
		"spacing": {
			"units": [ "%", "px", "em", "rem", "vh", "vw" ],
			"spacingSizes": [
				{ "slug": "xx-small", "name": "XX Small", "size": "8px" },
				{ "slug": "x-small",  "name": "X Small",  "size": "12px" },
				{ "slug": "small",    "name": "Small",    "size": "16px" },
				{ "slug": "medium",   "name": "Medium",   "size": "24px" },
				{ "slug": "large",    "name": "Large",    "size": "32px" },
				{ "slug": "x-large",  "name": "X Large",  "size": "48px" },
				{ "slug": "xx-large", "name": "XX Large", "size": "64px" }
			]
		},
		"color": {
			"palette": [
				{ "slug": "primary",       "name": "Dark",          "color": "#0A0A0A" },
				{ "slug": "secondary",     "name": "Off White",     "color": "#F7F7F7" },
				{ "slug": "tertiary",      "name": "Light Grey",    "color": "#E0E0E0" },
				{ "slug": "background",    "name": "White",         "color": "#FFFFFF" },
				{ "slug": "accent-orange", "name": "Accent Orange", "color": "#FFA370" }
			]
		},
		"typography": {
			"fluid": false,
			"fontFamilies": [
				{
					"fontFamily": "'PP Mori', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
					"name": "PP Mori",
					"slug": "pp-mori",
					"fontFace": [
						{ "fontFamily": "PP Mori", "fontWeight": "400", "fontStyle": "normal", "fontDisplay": "swap", "src": [ "file:./assets/fonts/PPMori-Regular.woff2" ] },
						{ "fontFamily": "PP Mori", "fontWeight": "700", "fontStyle": "normal", "fontDisplay": "swap", "src": [ "file:./assets/fonts/PPMori-Bold.woff2" ] },
						{ "fontFamily": "PP Mori", "fontWeight": "400", "fontStyle": "italic", "fontDisplay": "swap", "src": [ "file:./assets/fonts/PPMori-RegularItalic.woff2" ] },
						{ "fontFamily": "PP Mori", "fontWeight": "700", "fontStyle": "italic", "fontDisplay": "swap", "src": [ "file:./assets/fonts/PPMori-BoldItalic.woff2" ] }
					]
				},
				{
					"fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
					"name": "System",
					"slug": "system"
				}
			],
			"fontSizes": [
				{ "slug": "small",    "name": "Small (16)",              "size": "16px" },
				{ "slug": "base",     "name": "Base (17-20)",            "size": "clamp(17px, calc(17px + 3 * ((100vw - 768px) / 1152)), 20px)" },
				{ "slug": "medium",   "name": "Medium (20-26)",          "size": "clamp(20px, calc(20px + 6 * ((100vw - 768px) / 1152)), 26px)" },
				{ "slug": "large",    "name": "Large (28-40)",           "size": "clamp(28px, calc(28px + 12 * ((100vw - 768px) / 1152)), 40px)" },
				{ "slug": "x-large",  "name": "X Large (32-56)",         "size": "clamp(32px, calc(32px + 24 * ((100vw - 768px) / 1152)), 56px)" },
				{ "slug": "xx-large", "name": "Display (40-80)",         "size": "clamp(40px, calc(40px + 40 * ((100vw - 768px) / 1152)), 80px)" }
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"spacing": {
			"blockGap": "0px",
			"padding": { "top": "0px", "right": "0px", "bottom": "0px", "left": "0px" }
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--pp-mori)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.6"
		},
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--primary)"
		}
	},
	"templateParts": [
		{ "area": "header", "name": "header" },
		{ "area": "footer", "name": "footer" }
	]
}
