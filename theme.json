{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1000px",
			"wideSize": "1440px"
		},
		"spacing": {
			"units": [ "%", "px", "em", "rem", "vh", "vw" ],
			"spacingSizes": [
				{ "slug": "xx-small", "name": "XX Small", "size": "8px" },
				{ "slug": "x-small",  "name": "X Small",  "size": "12px" },
				{ "slug": "small",    "name": "Small",    "size": "16px" },
				{ "slug": "medium",   "name": "Medium",   "size": "24px" },
				{ "slug": "large",    "name": "Large",    "size": "32px" },
				{ "slug": "x-large",  "name": "X Large",  "size": "48px" },
				{ "slug": "xx-large", "name": "XX Large", "size": "64px" }
			]
		},
		"color": {
			"palette": [
				{ "slug": "primary",  "name": "Primary",  "color": "#1a1a1a" },
				{ "slug": "accent",   "name": "Accent",   "color": "#1a1a1a" },
				{ "slug": "base",     "name": "White",    "color": "#ffffff" },
				{ "slug": "contrast", "name": "Black",    "color": "#000000" },
				{ "slug": "surface",  "name": "Surface",  "color": "#f7f7f7" },
				{ "slug": "border",   "name": "Border",   "color": "#e9e9e9" },
				{ "slug": "text",     "name": "Text",     "color": "#1a1a1a" },
				{ "slug": "muted",    "name": "Muted",    "color": "#6b6b6b" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
					"name": "System",
					"slug": "system"
				}
			],
			"fontSizes": [
				{ "slug": "small",    "name": "Small",    "size": "16px" },
				{ "slug": "base",     "name": "Base",     "size": "18px" },
				{ "slug": "medium",   "name": "Medium",   "size": "24px" },
				{ "slug": "large",    "name": "Large",    "size": "32px" },
				{ "slug": "x-large",  "name": "X Large",  "size": "clamp(32px, calc(32px + 8 * ((100vw - 768px) / 672)), 40px)" },
				{ "slug": "xx-large", "name": "XX Large", "size": "clamp(32px, calc(32px + 16 * ((100vw - 768px) / 672)), 48px)" }
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.5"
		},
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--text)"
		}
	},
	"templateParts": [
		{ "area": "header", "name": "header" },
		{ "area": "footer", "name": "footer" }
	]
}
